# Karwan environment template.
#
# Copy this file to `.env` and fill in real values. Never commit the real .env.
# Every variable the backend reads is listed here, grouped by subsystem.
# Optional variables show their in-code default so you know what omitting them costs.

# Runtime

# Runtime environment: development | production | test
NODE_ENV=development
# Port the Hono API listens on
PORT=8787
# pino log level: trace | debug | info | warn | error
LOG_LEVEL=info
# When set to "1", skip starting the buyer + seller agent watchers on boot.
# Useful for one-shot scripts (cron jobs, indexers) that share the codebase.
SKIP_AGENTS=

# Chain: Arc testnet

# Arc Testnet RPC + WSS. Defaults work for low-volume dev; set private endpoints
# (Alchemy / QuickNode / your own node) once you hit public-RPC rate limits.
ARC_TESTNET_RPC_URL=https://rpc.testnet.arc.network
ARC_TESTNET_WSS_URL=wss://rpc.testnet.arc.network
ARC_TESTNET_EXPLORER_URL=https://testnet.arcscan.app

# Source-chain RPCs used by the frontend CCTP bridge (Base Sepolia, Ethereum
# Sepolia). Optional. NEXT_PUBLIC_* prefix exposes them to the browser since
# they live in wagmi's transport config.
NEXT_PUBLIC_BASE_SEPOLIA_RPC=
NEXT_PUBLIC_SEPOLIA_RPC=

# ERC-8004 registries (existing on Arc)

IDENTITY_REGISTRY_ADDR=0x8004A818BFB912233c491871b3d84c89A494BD9e
REPUTATION_REGISTRY_ADDR=0x8004B663056A597Dffe9eCcC1965A193B7388713
VALIDATION_REGISTRY_ADDR=0x8004Cb1BF31DAf7788923b405b754f57acEB4272
# ERC-8183 escrow reference (used if KarwanEscrow wraps rather than reimplements)
ERC8183_REF_ADDR=0x0747EEf0706327138c69792bF28Cd525089e4583
# USDC ERC-20 on Arc Testnet
USDC_ADDR=0x3600000000000000000000000000000000000000

# Karwan contracts

# Populated after `forge script Deploy`. Leave blank pre-deploy.
KARWAN_JOBBOARD_ADDR=
KARWAN_ESCROW_ADDR=
KARWAN_REPUTATION_ADDR=
KARWAN_VAULT_ADDR=

# Block at which KarwanVault was deployed. When set, the vault log scanner
# anchors its cold scan here instead of walking back a large default window —
# huge difference on Arc, where the default 5M-block window is 484+ pages of
# empty pre-deploy reads. With this set, only the ~150 pages between deploy
# and head get walked.
#
# Production: set this to the deploy block reported by
# `contracts/broadcast/DeployVault.s.sol/5042002/run-latest.json` -> receipts[0].blockNumber.
# Current Arc Testnet vault deploy: 42653233. Re-set this whenever you
# redeploy KarwanVault (and bump KARWAN_VAULT_ADDR alongside).
#
# Leaving it blank works but causes the credit-passport flicker: the cold
# scan hits the MAX_PAGES cap before reaching head, so two reads can return
# different partial totals depending on cache state. Always set it in any
# environment that serves real users.
KARWAN_VAULT_DEPLOY_BLOCK=

# Platform fee in basis points (150 = 1.5%), split evenly between buyer and
# seller. Read by the Deploy script when constructing KarwanEscrow.
KARWAN_FEE_BPS=150
# Treasury wallet that collects the platform fee. Must match the address the
# escrow was deployed with.
KARWAN_TREASURY_ADDR=

# --- USYC reserves (Track 2) ---
# MockUSYC stand-in for Hashnote/Circle USYC. Combines token + Teller + oracle in
# one testnet contract. Populate after `forge script DeployMockUSYC`. On mainnet
# point USYC_TELLER/TOKEN/ORACLE at the three real addresses instead.
# Feature flag for the App Kit migration. Documentation-only at the backend
# (the hand-rolled and App Kit bridges live at separate endpoints:
# /api/bridge/circle-bridge vs /api/bridge/circle-bridge-app-kit). The flag
# records the operator's intent for which path is canonical; the frontend
# can read it via /api/agents/status when wired up. true also enables Solana
# Devnet as a source chain (only the App Kit path supports it).
BRIDGE_USE_APP_KIT=

# Circle webhook subscription ID for the dev-controlled-wallets event stream.
# Created in the Circle Developer Console (Webhooks tab) once per environment.
# When unset, POST /api/circle/webhook returns 503 "not configured" and the
# polling path in chain/txs.ts is the only completion signal. When set, the
# backend additionally receives signed event push notifications via ECDSA-SHA256
# (X-Circle-Signature / X-Circle-Key-Id headers, verified against the per-
# subscription public key fetched from getNotificationSignature).
CIRCLE_WEBHOOK_SUBSCRIPTION_ID=

USYC_TELLER_ADDR=
USYC_TOKEN_ADDR=
USYC_ORACLE_ADDR=
# Annual yield the mock ramps its price by (basis points, 500 = 5%).
USYC_APY_BPS=500
# KarwanTreasury CONTRACT (parks idle USDC reserves in USYC). Distinct from
# KARWAN_TREASURY_ADDR above (the EOA fee collector). Populate after
# `forge script DeployTreasury`. Read by GET /api/admin/treasury.
KARWAN_TREASURY_CONTRACT_ADDR=
# Automation wallet allowed to sweep idle USDC into USYC. Defaults to the
# deployer when unset.
TREASURY_KEEPER_ADDR=
# USDC kept liquid (6 decimals); only the balance above this is swept. 0 = sweep all.
TREASURY_IDLE_THRESHOLD=

# Throwaway EOA used only to deploy the Karwan contracts. Fund with USDC for
# gas (USDC is the native gas asset on Arc). Generate with `openssl rand -hex 32`.
# Never commit the real value.
DEPLOYER_PRIVATE_KEY=

# Escrow review windows

# Buyer's window to release each milestone after delivery (ms). After this
# expires the deal watcher auto-releases. Default 5 min for demos; raise to
# hours for mainnet.
DEAL_REVIEW_WINDOW_MS=300000
# Each "still reviewing" tip adds this much time to the final-release window.
DEAL_REVIEW_EXTENSION_MS=600000
# How many times the buyer can extend the final-release window.
DEAL_MAX_REVIEW_EXTENSIONS=3

# CCTP V2

# Arc's MessageTransmitterV2 (where receiveMessage is called to mint).
CCTP_MESSAGE_TRANSMITTER_ADDR=0xE737e5cEBEEBa77EFE34D4aa090756590b1CE275
# Circle CCTP V2 attestation API. Sandbox base covers all V2 testnets.
IRIS_API_BASE=https://iris-api-sandbox.circle.com

# Circle developer-controlled wallets
# console.circle.com -> Keys -> Create a key -> API key (Standard Key)

CIRCLE_API_KEY=
# Entity secret registered with Circle per the SDK setup
CIRCLE_ENTITY_SECRET=
# Wallet set ID for the two agent wallets (populated by `npm run wallets:create`)
CIRCLE_WALLET_SET_ID=

# Agent wallets (populated by `npm run wallets:create`)
BUYER_AGENT_WALLET_ID=
BUYER_AGENT_ADDRESS=
SELLER_AGENT_WALLET_ID=
SELLER_AGENT_ADDRESS=

# Gas Station sponsorship. CIRCLE_GAS_STATION_ENABLED=true tells the bridge
# precheck to trust an active Console policy (skips the "wallet has native
# gas" check for sponsored chains). The Console policy is per-chain, so the
# SPONSORED_CHAINS list MUST mirror what is enabled in the Console. Leaving
# it empty falls back to "sponsor every chain when ENABLED is on" (back-
# compat with pre-whitelist behaviour), which silently breaks bridges from
# any source chain not actually covered by the Console policy.
#
# Today's prod policy: Base Sepolia + Ethereum Sepolia only. Set to:
#   CIRCLE_GAS_STATION_SPONSORED_CHAINS=baseSepolia,sepolia
# Update both this list and the Console policy together whenever you add
# sponsorship for another chain (arbitrumSepolia, optimismSepolia,
# polygonAmoy).
CIRCLE_GAS_STATION_ENABLED=false
CIRCLE_GAS_STATION_SPONSORED_CHAINS=

# LLM (OpenRouter)

# openrouter.ai/keys -- used for all agent LLM calls
OPENROUTER_API_KEY=
# OpenRouter model slug (NOT a display name). Examples:
#   google/gemini-2.5-flash-lite (cheap, fast, occasional schema misses)
#   moonshotai/kimi-k2.5 (smarter, slower, raise LLM_TIMEOUT_MS)
#   anthropic/claude-haiku-4-5
LLM_MODEL=google/gemini-2.5-flash-lite
# Hard timeout per LLM call in ms. Default 45s; bump to 60-90s for heavier
# models like Kimi K2.5. Throws agent.error if exceeded -- the loop logs and
# moves on rather than wedging the per-(jobId, seller) mutex.
LLM_TIMEOUT_MS=45000

# How long the buyer agent waits for a seller's on-chain CounterResponse before
# treating the negotiation as stalled and cascading to the next candidate.
# Must clear the seller's worst-case reply: one LLM call (LLM_TIMEOUT_MS) plus a
# Circle contract call (polled up to ~90s). Default 180s. This is the recovery
# net for a seller that declined off-chain, a dropped event, or a seller crash.
NEGOTIATION_RESPONSE_TIMEOUT_MS=180000

# Postgres

# Postgres connection string. Optional in dev -- flat-file fallback under
# backend/data/ kicks in when unset. REQUIRED for production: VPS reboots
# wipe the in-memory caches and you'll lose deal history.
# Neon (free tier) example:
#   postgresql://user:pass@ep-xxx.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# Telegram bot

# Optional. When unset, the bot module no-ops and /telegram routes report
# "not configured". Set both to enable Telegram link + notifications.
# Token: @BotFather -> /newbot -> copy the token.
TELEGRAM_BOT_TOKEN=
# Bot username without the @
TELEGRAM_BOT_USERNAME=

# Frontend origin

# Public URL of the frontend. Used to embed deep links in Telegram + email
# so a user can tap from their phone and land on the deal page. In dev set
# to http://localhost:3000; in production to https://karwan.site.
FRONTEND_BASE_URL=http://localhost:3000

# Feedback

# Telegram chat that receives tester feedback from /feedback. When set (and the
# bot token above is configured), each submission is forwarded here with its
# screenshots. Find your chat id by messaging @userinfobot. Leave blank to just
# store feedback (read it back at GET /api/feedback).
FEEDBACK_TELEGRAM_CHAT_ID=
# This backend's own public origin, e.g. https://api.karwan.site. Needed for
# Telegram to fetch feedback screenshots and for the viewer to link them. Leave
# blank in dev; set in production.
PUBLIC_API_BASE_URL=

# Admin

# Shared secret gating /api/admin/* and the feedback list/status endpoints.
# Send it as the `X-Admin-Token` header. Fail-closed: when blank, the admin
# surface is disabled (503), not open. Set a long random value in production,
# e.g. `openssl rand -hex 32`.
ADMIN_API_TOKEN=

# X (OAuth 2.0 PKCE)

# X dev app at developer.x.com. Scopes: user.read + tweet.read. Allowlist
# the redirect URI. Leave unset to fall back to manual handle entry.
X_CLIENT_ID=
X_CLIENT_SECRET=
X_REDIRECT_URI=http://localhost:8787/api/x/oauth/callback

# Auth (sessions + passkeys)

# SESSION_SECRET signs session cookies. Pick any random 32+ char string; rotate
# to invalidate every session at once. `openssl rand -hex 64` is the easy way.
SESSION_SECRET=dev-secret-change-me-please-32-chars-min
# Passkey config. RP_ID is the hostname (no scheme, no port). ORIGIN is the
# full https origin browsers will hold credentials for. Production: set RP_ID
# to your real domain (e.g. karwan.site) and ORIGIN to https://karwan.site.
# WARNING: changing RP_ID invalidates every existing passkey credential.
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=Karwan
WEBAUTHN_ORIGIN=http://localhost:3000

# Email (Resend)

# resend.com -> API Keys. Without RESEND_API_KEY the OTP route logs codes to
# stdout and the dev modal auto-fills (no real email sent).
RESEND_API_KEY=
# Sender address. `Karwan <onboarding@resend.dev>` is Resend's sandbox sender
# (works without DNS setup but only delivers to your signup email). For
# production, verify your domain in Resend and use a noreply@karwan.site sender.
RESEND_FROM=Karwan <onboarding@resend.dev>

# Reputation engine tuning
#
# Model v2 (additive). Full formula in docs/reputation-model.md §2. Tier
# breakpoints (200/400/600/800) are FIXED in code now, not env. the score scale
# is the lever. The vars below are weights (sum to 1) + saturation caps. Testnet
# defaults reach tiers in days; raise the caps for mainnet to make tiers harder.
#
# NOTE: the old REP_TIER_*, REP_TIME_RAMP_DAYS, and REP_ACTIVITY_HALF vars are no
# longer read. remove them from your .env. REP_STAKE_CAP_USDC is reused (now the
# raw stake-amount cap, default 100).

# Additive base weights. Stake-forward (staking is the strongest lever).
REP_W_STAKE=0.30
REP_W_COMPLETION=0.25
REP_W_VOLUME=0.13
REP_W_TENURE=0.12
REP_W_ACTIVITY=0.12
REP_W_REFERRAL=0.08

# Concave saturation caps (testnet-friendly). Raise for mainnet.
REP_DEALS_CAP=10
REP_STAKE_CAP_USDC=100
REP_STAKE_FULL_DAYS=14
REP_STAKE_FLOOR_CREDIT=0.4
REP_TENURE_FULL_DAYS=14
REP_ACTIVE_DAYS_CAP=14
REP_REFERRAL_CAP=5
REP_VOLUME_CAP_USDC=500

# Penalty: applied as a capped multiplier (1 - penalty), never zeroes an account.
REP_PENALTY_CAP=0.6
REP_PENALTY_DISPUTE_W=0.5
REP_PENALTY_CANCEL_W=0.12
REP_PENALTY_SPAM_W=0.2
REP_PENALTY_ABANDON_W=0.08

# Days of inactivity that halve the displayed score.
REP_DECAY_HALFLIFE_DAYS=180
# Burst-rate threshold for spam (24h posts before each extra counts as spam).
REP_SPAM_BURST_LIMIT=5

# Scripts / CLI helpers

# backend/src/scripts/view-cli.ts uses BACKEND_URL when called outside the
# server context. Defaults to http://localhost:8787.
BACKEND_URL=http://localhost:8787

# backend/src/scripts/post-test-job.ts overrides -- only read when the script
# runs. Safe to leave unset.
JOB_BRIEF=
JOB_BUDGET_USDC=
JOB_DEADLINE_DAYS=
JOB_ID=
MILESTONES=

# backend/src/scripts/register-identities.ts metadata URIs -- usually unset,
# the script falls back to repo-default metadata.
BUYER_METADATA_URI=
SELLER_METADATA_URI=

# backend/src/scripts/{buyer,seller}-agent.ts -- set BACKFILL=1 to scan
# historical events on script start (rare, default is forward-only).
BACKFILL=
