# Runtime environment: development | production | test
NODE_ENV=development
# Port the Hono API listens on
PORT=8787
# pino log level: trace | debug | info | warn | error
LOG_LEVEL=info

# Arc Testnet RPC (defaults work; override with a private RPC for higher rate limits)
ARC_TESTNET_RPC_URL=https://rpc.testnet.arc.network
ARC_TESTNET_WSS_URL=wss://rpc.testnet.arc.network
ARC_TESTNET_EXPLORER_URL=https://testnet.arcscan.app

# Existing reference deployments on Arc Testnet
IDENTITY_REGISTRY_ADDR=0x8004A818BFB912233c491871b3d84c89A494BD9e
REPUTATION_REGISTRY_ADDR=0x8004B663056A597Dffe9eCcC1965A193B7388713
VALIDATION_REGISTRY_ADDR=0x8004Cb1BF31DAf7788923b405b754f57acEB4272
# ERC-8183 escrow reference (used by KarwanEscrow if we wrap rather than reimplement)
ERC8183_REF_ADDR=0x0747EEf0706327138c69792bF28Cd525089e4583
# USDC ERC-20 token address on Arc Testnet
USDC_ADDR=0x3600000000000000000000000000000000000000

# Karwan contract addresses (populated after `forge script Deploy`)
KARWAN_JOBBOARD_ADDR=
KARWAN_ESCROW_ADDR=
KARWAN_REPUTATION_ADDR=

# Circle Developer Console credentials (https://console.circle.com)
# API key: Keys → Create a key → API key → Standard Key
CIRCLE_API_KEY=
# Entity secret registered with Circle per the SDK setup
CIRCLE_ENTITY_SECRET=
# Wallet set ID for the two agent wallets (populated by `npm run wallets:create`)
CIRCLE_WALLET_SET_ID=

# Agent wallets (populated by `npm run wallets:create`)
BUYER_AGENT_WALLET_ID=
BUYER_AGENT_ADDRESS=
SELLER_AGENT_WALLET_ID=
SELLER_AGENT_ADDRESS=

# Anthropic API key for the agent LLM
ANTHROPIC_API_KEY=
# Default LLM model used by agent loops
LLM_MODEL=claude-haiku-4-5-20251001

# Postgres URL for audit log (optional in v0)
DATABASE_URL=
