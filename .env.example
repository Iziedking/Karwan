# ----------------------------------------------------------------------------
# Karwan environment template.
#
# Copy this file to `.env` and fill in real values. Never commit the real .env.
# Every variable that the backend reads is listed here, grouped by subsystem.
# Optional variables show the in-code default so you know what you'd lose by
# omitting them.
# ----------------------------------------------------------------------------

# ====================== RUNTIME ============================================

# Runtime environment: development | production | test
NODE_ENV=development
# Port the Hono API listens on
PORT=8787
# pino log level: trace | debug | info | warn | error
LOG_LEVEL=info
# When set to "1", skip starting the buyer + seller agent watchers on boot.
# Useful for one-shot scripts (cron jobs, indexers) that share the codebase.
SKIP_AGENTS=

# ====================== CHAIN: ARC TESTNET =================================

# Arc Testnet RPC + WSS. Defaults work for low-volume dev; set private endpoints
# (Alchemy / QuickNode / your own node) once you hit public-RPC rate limits.
ARC_TESTNET_RPC_URL=https://rpc.testnet.arc.network
ARC_TESTNET_WSS_URL=wss://rpc.testnet.arc.network
ARC_TESTNET_EXPLORER_URL=https://testnet.arcscan.app

# Source-chain RPCs used by the frontend CCTP bridge (Base Sepolia, Ethereum
# Sepolia). Optional. NEXT_PUBLIC_* prefix exposes them to the browser since
# they live in wagmi's transport config.
NEXT_PUBLIC_BASE_SEPOLIA_RPC=
NEXT_PUBLIC_SEPOLIA_RPC=

# ====================== ERC-8004 REGISTRIES (existing on Arc) ==============

IDENTITY_REGISTRY_ADDR=0x8004A818BFB912233c491871b3d84c89A494BD9e
REPUTATION_REGISTRY_ADDR=0x8004B663056A597Dffe9eCcC1965A193B7388713
VALIDATION_REGISTRY_ADDR=0x8004Cb1BF31DAf7788923b405b754f57acEB4272
# ERC-8183 escrow reference (used if KarwanEscrow wraps rather than reimplements)
ERC8183_REF_ADDR=0x0747EEf0706327138c69792bF28Cd525089e4583
# USDC ERC-20 on Arc Testnet
USDC_ADDR=0x3600000000000000000000000000000000000000

# ====================== KARWAN CONTRACTS ===================================

# Populated after `forge script Deploy`. Leave blank pre-deploy.
KARWAN_JOBBOARD_ADDR=
KARWAN_ESCROW_ADDR=
KARWAN_REPUTATION_ADDR=
KARWAN_VAULT_ADDR=

# Block at which KarwanVault was deployed. When set, the reputation engine's
# paginated event reader starts here instead of walking back a large default
# window. Set in production to avoid scanning empty pre-deploy blocks on every
# read. Leave blank during fresh testnet sessions.
KARWAN_VAULT_DEPLOY_BLOCK=

# Platform fee in basis points (150 = 1.5%), split evenly between buyer and
# seller. Read by the Deploy script when constructing KarwanEscrow.
KARWAN_FEE_BPS=150
# Treasury wallet that collects the platform fee. Must match the address the
# escrow was deployed with.
KARWAN_TREASURY_ADDR=

# Throwaway EOA used only to deploy the Karwan contracts. Fund with USDC for
# gas (USDC is the native gas asset on Arc). Generate with `openssl rand -hex 32`.
# Never commit the real value.
DEPLOYER_PRIVATE_KEY=

# ====================== ESCROW REVIEW WINDOWS ==============================

# Buyer's window to release each milestone after delivery (ms). After this
# expires the deal watcher auto-releases. Default 5 min for demos; raise to
# hours for mainnet.
DEAL_REVIEW_WINDOW_MS=300000
# Each "still reviewing" tip adds this much time to the final-release window.
DEAL_REVIEW_EXTENSION_MS=600000
# How many times the buyer can extend the final-release window.
DEAL_MAX_REVIEW_EXTENSIONS=3

# ====================== CCTP V2 ============================================

# Arc's MessageTransmitterV2 (where receiveMessage is called to mint).
CCTP_MESSAGE_TRANSMITTER_ADDR=0xE737e5cEBEEBa77EFE34D4aa090756590b1CE275
# Circle CCTP V2 attestation API. Sandbox base covers all V2 testnets.
IRIS_API_BASE=https://iris-api-sandbox.circle.com

# ====================== CIRCLE DEVELOPER-CONTROLLED WALLETS ================
# https://console.circle.com → Keys → Create a key → API key (Standard Key)

CIRCLE_API_KEY=
# Entity secret registered with Circle per the SDK setup
CIRCLE_ENTITY_SECRET=
# Wallet set ID for the two agent wallets (populated by `npm run wallets:create`)
CIRCLE_WALLET_SET_ID=

# Agent wallets (populated by `npm run wallets:create`)
BUYER_AGENT_WALLET_ID=
BUYER_AGENT_ADDRESS=
SELLER_AGENT_WALLET_ID=
SELLER_AGENT_ADDRESS=

# ====================== LLM (OpenRouter) ===================================

# https://openrouter.ai/keys — used for all agent LLM calls
OPENROUTER_API_KEY=
# OpenRouter model slug (NOT a display name). Examples:
#   google/gemini-2.5-flash-lite (cheap, fast, occasional schema misses)
#   moonshotai/kimi-k2.5 (smarter, slower, raise LLM_TIMEOUT_MS)
#   anthropic/claude-haiku-4-5
LLM_MODEL=google/gemini-2.5-flash-lite
# Hard timeout per LLM call in ms. Default 45s; bump to 60-90s for heavier
# models like Kimi K2.5. Throws agent.error if exceeded — the loop logs and
# moves on rather than wedging the per-(jobId, seller) mutex.
LLM_TIMEOUT_MS=45000

# ====================== POSTGRES ===========================================

# Postgres connection string. Optional in dev — flat-file fallback under
# backend/data/ kicks in when unset. REQUIRED for production: VPS reboots
# wipe the in-memory caches and you'll lose deal history.
# Neon (free tier) example:
#   postgresql://user:pass@ep-xxx.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# ====================== TELEGRAM BOT =======================================

# Optional. When unset, the bot module no-ops and /telegram routes report
# "not configured". Set both to enable Telegram link + notifications.
# Token: @BotFather → /newbot → copy the token.
TELEGRAM_BOT_TOKEN=
# Bot username without the @
TELEGRAM_BOT_USERNAME=

# ====================== FRONTEND ORIGIN ====================================

# Public URL of the frontend. Used to embed deep links in Telegram + email
# so a user can tap from their phone and land on the deal page. In dev set
# to http://localhost:3000; in production to https://karwan.site.
FRONTEND_BASE_URL=http://localhost:3000

# ====================== X (OAUTH 2.0 PKCE) =================================

# X dev app at developer.x.com. Scopes: user.read + tweet.read. Allowlist
# the redirect URI. Leave unset to fall back to manual handle entry.
X_CLIENT_ID=
X_CLIENT_SECRET=
X_REDIRECT_URI=http://localhost:8787/api/x/oauth/callback

# ====================== AUTH (Sessions + Passkeys) =========================

# SESSION_SECRET signs session cookies. Pick any random 32+ char string; rotate
# to invalidate every session at once. `openssl rand -hex 64` is the easy way.
SESSION_SECRET=dev-secret-change-me-please-32-chars-min
# Passkey config. RP_ID is the hostname (no scheme, no port). ORIGIN is the
# full https origin browsers will hold credentials for. Production: set RP_ID
# to your real domain (e.g. karwan.site) and ORIGIN to https://karwan.site.
# WARNING: changing RP_ID invalidates every existing passkey credential.
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=Karwan
WEBAUTHN_ORIGIN=http://localhost:3000

# ====================== EMAIL (Resend) =====================================

# https://resend.com → API Keys. Without RESEND_API_KEY the OTP route logs
# codes to stdout and the dev modal auto-fills (no real email sent).
RESEND_API_KEY=
# Sender address. `Karwan <onboarding@resend.dev>` is Resend's sandbox sender
# (works without DNS setup but only delivers to your signup email). For
# production, verify your domain in Resend and use a noreply@karwan.site sender.
RESEND_FROM=Karwan <onboarding@resend.dev>

# ====================== REPUTATION ENGINE TUNING ===========================
#
# Defaults documented in backend/src/reputation/config.ts. Override to make
# testnet behaviour easier to demo (lower tier thresholds, faster time ramp)
# or to tighten production behaviour.

# Saturates activityTerm. N completed deals → activity = 1.0
REP_ACTIVITY_HALF=50
# Tenure-weighted stake at which stakeTerm caps at 2.0 (USDC)
REP_STAKE_CAP_USDC=1000
# Days to reach full timeTerm
REP_TIME_RAMP_DAYS=90
# Days of inactivity that halve the displayed score
REP_DECAY_HALFLIFE_DAYS=180
# Burst-rate threshold for spam (24h posts before each extra counts as spam)
REP_SPAM_BURST_LIMIT=5

# Tier lower-bound scores out of 1000. Below tierNew = NEW; >=tierStrong = ELITE
REP_TIER_NEW=200
REP_TIER_COLD=400
REP_TIER_ESTABLISHED=600
REP_TIER_STRONG=800

# Penalty weights. Sum is clamped to 1 in the formula.
REP_PENALTY_DISPUTE_W=0.3
REP_PENALTY_CANCEL_W=0.15
REP_PENALTY_SPAM_W=0.4
REP_PENALTY_ABANDON_W=0.1

# ====================== SCRIPTS / CLI HELPERS ==============================

# backend/src/scripts/view-cli.ts uses BACKEND_URL when called outside the
# server context. Defaults to http://localhost:8787.
BACKEND_URL=http://localhost:8787

# backend/src/scripts/post-test-job.ts overrides — only read when the script
# runs. Safe to leave unset.
JOB_BRIEF=
JOB_BUDGET_USDC=
JOB_DEADLINE_DAYS=
JOB_ID=
MILESTONES=

# backend/src/scripts/register-identities.ts metadata URIs — usually unset,
# the script falls back to repo-default metadata.
BUYER_METADATA_URI=
SELLER_METADATA_URI=

# backend/src/scripts/{buyer,seller}-agent.ts — set BACKFILL=1 to scan
# historical events on script start (rare, default is forward-only).
BACKFILL=
