{
  "name": "karwan",
  "version": "0.0.1",
  "private": true,
  "description": "Agentic settlement and reputation rails for cross-border SME trade on Arc",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently -n backend,frontend -c blue,magenta \"npm:dev:backend\" \"npm:dev:frontend\"",
    "dev:backend": "npm run dev --workspace=backend",
    "dev:frontend": "npm run dev --workspace=frontend",
    "build": "npm run build --workspace=backend && npm run build --workspace=frontend",
    "smoke-test": "npm run smoke-test --workspace=backend",
    "abis:sync": "npm run abis:sync --workspace=backend",
    "typecheck": "npm run typecheck --workspace=backend && npm run typecheck --workspace=frontend",
    "entity-secret:register": "npm run entity-secret:register --workspace=backend",
    "wallets:create": "npm run wallets:create --workspace=backend",
    "identity:register": "npm run identity:register --workspace=backend",
    "agent:seller": "npm run agent:seller --workspace=backend",
    "agent:buyer": "npm run agent:buyer --workspace=backend",
    "job:post": "npm run job:post --workspace=backend",
    "milestones:release": "npm run milestones:release --workspace=backend",
    "contracts:build": "cd contracts && forge build",
    "contracts:test": "cd contracts && forge test -vv"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
