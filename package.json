{
  "name": "karwan",
  "version": "0.0.1",
  "private": true,
  "description": "Agentic settlement and reputation rails for cross-border SME trade on Arc",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=backend",
